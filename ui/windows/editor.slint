                    if ta.pressed && root.tool == 1: Rectangle {
                        x: Math.min(ta.pressed-x, root.end-x);
                        y: Math.min(ta.pressed-y, root.end-y);
                        width: Math.abs(root.end-x - ta.pressed-x);
                        height: Math.abs(root.end-y - ta.pressed-y);
                        background: root.fill ? root.draw-color.with-alpha(0.25) : transparent;
                        border-width: root.draw-width;
                        border-color: root.draw-color;
                        border-radius: Math.min(self.width, self.height) * 0.08;
                    }
                    // Pixelate region marker (the blur itself is applied on commit).
                    if ta.pressed && root.tool == 5: Rectangle {
                        x: Math.min(ta.pressed-x, root.end-x);
                        y: Math.min(ta.pressed-y, root.end-y);
                        width: Math.abs(root.end-x - ta.pressed-x);
                        height: Math.abs(root.end-y - ta.pressed-y);
                        background: #ffffff20;
                        border-width: 1px;
                        border-color: #ffffffaa;
                    }
                    // Ellipse preview — a true oval (cubic-bezier quarters), so it
                    // matches the committed shape instead of looking like a pill.
                    if ta.pressed && root.tool == 2: Path {
                        width: 100%;
                        height: 100%;
                        viewbox-width: ta.width / 1px;
                        viewbox-height: ta.height / 1px;
                        property <float> cx: (ta.pressed-x + root.end-x) / 2 / 1px;
                        property <float> cy: (ta.pressed-y + root.end-y) / 2 / 1px;
                        property <float> rx: Math.abs((root.end-x - ta.pressed-x) / 1px) / 2;
                        property <float> ry: Math.abs((root.end-y - ta.pressed-y) / 1px) / 2;
                        property <float> kx: rx * 0.5523;
                        property <float> ky: ry * 0.5523;
                        fill: root.fill ? root.draw-color.with-alpha(0.25) : transparent;
                        stroke: root.draw-color;
                        stroke-width: root.draw-width;
                        MoveTo { x: parent.cx - parent.rx; y: parent.cy; }
                        CubicTo { control-1-x: parent.cx - parent.rx; control-1-y: parent.cy - parent.ky; control-2-x: parent.cx - parent.kx; control-2-y: parent.cy - parent.ry; x: parent.cx; y: parent.cy - parent.ry; }
                        CubicTo { control-1-x: parent.cx + parent.kx; control-1-y: parent.cy - parent.ry; control-2-x: parent.cx + parent.rx; control-2-y: parent.cy - parent.ky; x: parent.cx + parent.rx; y: parent.cy; }
                        CubicTo { control-1-x: parent.cx + parent.rx; control-1-y: parent.cy + parent.ky; control-2-x: parent.cx + parent.kx; control-2-y: parent.cy + parent.ry; x: parent.cx; y: parent.cy + parent.ry; }
                        CubicTo { control-1-x: parent.cx - parent.kx; control-1-y: parent.cy + parent.ry; control-2-x: parent.cx - parent.rx; control-2-y: parent.cy + parent.ky; x: parent.cx - parent.rx; y: parent.cy; }
                        Close { }
                    }
                    // Arrow + line share a straight segment preview.
                    if ta.pressed && (root.tool == 0 || root.tool == 3): Path {
                        width: 100%;
                        height: 100%;
                        viewbox-width: ta.width / 1px;
                        viewbox-height: ta.height / 1px;
                        commands: "M \{ta.pressed-x / 1px} \{ta.pressed-y / 1px} L \{root.end-x / 1px} \{root.end-y / 1px}";
                        stroke: root.draw-color;
                        stroke-width: root.draw-width;
                        fill: transparent;
                    }
                    // Highlighter — thick, translucent marker stroke.
                    if ta.pressed && root.tool == 4: Path {
                        width: 100%;
                        height: 100%;
                        viewbox-width: ta.width / 1px;
                        viewbox-height: ta.height / 1px;
                        commands: "M \{ta.pressed-x / 1px} \{ta.pressed-y / 1px} L \{root.end-x / 1px} \{root.end-y / 1px}";
                        stroke: root.draw-color.with-alpha(0.4);
                        stroke-width: root.draw-width * 4;
                        fill: transparent;
                    }
                    // Crop overlay — dim outside + dashed-style frame + 8 handles.
                    // A full-stage TouchArea owns the gesture: press picks a handle
