                            if (root.crop-handle == 1) { root.crop-l = Math.clamp(cta.mouse-x, root.crop-ix0, root.crop-r - 16px); root.crop-t = Math.clamp(cta.mouse-y, root.crop-iy0, root.crop-b - 16px); }
                            if (root.crop-handle == 2) { root.crop-t = Math.clamp(cta.mouse-y, root.crop-iy0, root.crop-b - 16px); }
                            if (root.crop-handle == 3) { root.crop-r = Math.clamp(cta.mouse-x, root.crop-l + 16px, root.crop-ix1); root.crop-t = Math.clamp(cta.mouse-y, root.crop-iy0, root.crop-b - 16px); }
                            if (root.crop-handle == 4) { root.crop-r = Math.clamp(cta.mouse-x, root.crop-l + 16px, root.crop-ix1); }
                            if (root.crop-handle == 5) { root.crop-r = Math.clamp(cta.mouse-x, root.crop-l + 16px, root.crop-ix1); root.crop-b = Math.clamp(cta.mouse-y, root.crop-t + 16px, root.crop-iy1); }
                            if (root.crop-handle == 6) { root.crop-b = Math.clamp(cta.mouse-y, root.crop-t + 16px, root.crop-iy1); }
                            if (root.crop-handle == 7) { root.crop-l = Math.clamp(cta.mouse-x, root.crop-ix0, root.crop-r - 16px); root.crop-b = Math.clamp(cta.mouse-y, root.crop-t + 16px, root.crop-iy1); }
                            if (root.crop-handle == 8) { root.crop-l = Math.clamp(cta.mouse-x, root.crop-ix0, root.crop-r - 16px); }
                            if (root.crop-handle == 9) {
