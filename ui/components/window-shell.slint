import { Theme } from "../theme.slint";

// THE window chrome for every Clipo panel/dialog: a rounded, 1px-bordered,
// drop-shadowed surface inset from the (transparent) Window by a margin so the
// shadow can float. Centralised so the radius, border, elevation and the
// "square + no shadow when maximized" rule live in one place — every window
// gets the same chrome by construction. The Window behind it MUST set
// `background: transparent` (so the margin is see-through); `@children` is the
// window's content. Maximizable windows pass `is-maximized` to fill squarely.
export component WindowShell inherits Rectangle {
    in property <color> bg: Theme.surface-0;
    in property <bool> is-maximized; // maximizable windows fill, no margin/shadow
    width: 100%;
    height: 100%;
    background: transparent;
    Rectangle {
        x: root.is-maximized ? 0 : 16px;
        y: root.is-maximized ? 0 : 16px;
        width: root.is-maximized ? parent.width : parent.width - 32px;
        height: root.is-maximized ? parent.height : parent.height - 32px;
        background: root.bg;
        border-radius: root.is-maximized ? 0 : 12px;
        border-width: root.is-maximized ? 0 : 1px;
        border-color: Theme.border-subtle;
        drop-shadow-blur: root.is-maximized ? 0px : 16px;
        drop-shadow-offset-y: root.is-maximized ? 0px : 4px;
        drop-shadow-color: #00000040;
        clip: true;
        @children
    }
}
