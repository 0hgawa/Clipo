                // when framed. Centred when the frame is off.
                Rectangle {
                    x: root.photo-x;
                    y: root.photo-y;
                    width: root.base-w * root.shot-scale * 1px;
                    height: root.base-h * root.shot-scale * 1px;
                    border-radius: root.bg-on ? root.bg-radius * root.shot-scale * 1px : 0;
                    clip: true;
                    Image { source: root.source; image-fit: ImageFit.fill; width: 100%; height: 100%; }
                }
                ta := TouchArea {
                    width: 100%;
                    height: 100%;
                    mouse-cursor: root.tool == 7 ? MouseCursor.move : MouseCursor.crosshair;
                    pointer-event(event) => {
                        if (event.kind == PointerEventKind.down && root.tool == 7) {
                            root.pick-move(ta.pressed-x, ta.pressed-y, ta.width, ta.height, root.zoom);
                        }
                        if (event.kind == PointerEventKind.down && root.tool == 10) {
                            root.pen-start(ta.pressed-x, ta.pressed-y, ta.width, ta.height, root.draw-color, root.stroke, root.zoom);
                        }
                        if (event.kind == PointerEventKind.up && root.tool == 10) {
                            root.pen-commit();
                        }
                        if (event.kind == PointerEventKind.up && root.tool != 7 && root.tool != 8 && root.tool != 10) {
                            if (root.tool == 6) {
                                // Commit any text in progress, then start a new one here.
                                if (root.text-editing) {
                                    root.add-text(root.text-x, root.text-y, stage.width, stage.height, root.text-buffer, root.draw-color, root.text-size, root.text-font, root.zoom);
                                }
                                root.text-x = ta.pressed-x;
                                root.text-y = ta.pressed-y;
                                root.text-buffer = "";
                                root.text-editing = true;
                                ti.focus();
                            } else if (root.tool == 9) {
                                root.add-badge(ta.pressed-x, ta.pressed-y, ta.width, ta.height, root.draw-color, root.stroke, root.zoom);
                            } else {
                                root.add-shape(root.tool, ta.pressed-x, ta.pressed-y, root.end-x, root.end-y, ta.width, ta.height, root.draw-color, root.stroke, root.zoom, root.fill);
