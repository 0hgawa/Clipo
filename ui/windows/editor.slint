                        property <length> bt: root.sw2wy(Math.min(root.sel-y1, root.sel-y2));
                        property <length> br: root.sw2wx(Math.max(root.sel-x1, root.sel-x2));
                        property <length> bb: root.sw2wy(Math.max(root.sel-y1, root.sel-y2));
                        Rectangle { x: parent.bl; y: parent.bt; width: parent.br - parent.bl; height: parent.bb - parent.bt; background: transparent; border-width: 1.5px; border-color: #fffffff2; }
                        if root.sel-line: CropHandle { cx: root.sw2wx(root.sel-x1); cy: root.sw2wy(root.sel-y1); }
                        if root.sel-line: CropHandle { cx: root.sw2wx(root.sel-x2); cy: root.sw2wy(root.sel-y2); }
                        if root.sel-box: CropHandle { cx: parent.bl; cy: parent.bt; }
                        if root.sel-box: CropHandle { cx: parent.br; cy: parent.bt; }
                        if root.sel-box: CropHandle { cx: parent.br; cy: parent.bb; }
                        if root.sel-box: CropHandle { cx: parent.bl; cy: parent.bb; }
                        if root.sel-box: CropHandle { pill-h: true; cx: (parent.bl + parent.br) / 2; cy: parent.bt; }
                        if root.sel-box: CropHandle { pill-h: true; cx: (parent.bl + parent.br) / 2; cy: parent.bb; }
                        if root.sel-box: CropHandle { pill-v: true; cx: parent.br; cy: (parent.bt + parent.bb) / 2; }
                        if root.sel-box: CropHandle { pill-v: true; cx: parent.bl; cy: (parent.bt + parent.bb) / 2; }
                    }
                }
                // Crop action bar — dims + Cancel + Apply, docked bottom-centre.
                if root.tool == 8 && root.crop-armed: Rectangle {
                    width: cropbar.preferred-width + 10px;
                    height: 40px;
                    x: (stage.width - self.width) / 2;
                    y: stage.height - self.height - 14px;
                    background: Theme.surface-2;
                    border-width: 1px;
                    border-color: Theme.border-subtle;
                    border-radius: Theme.radius-lg;
                    cropbar := HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 5px;
                        spacing: 8px;
                        VerticalLayout { alignment: center; Text { text: "\{Math.round((root.crop-r - root.crop-l) / 1px / root.shot-scale)} × \{Math.round((root.crop-b - root.crop-t) / 1px / root.shot-scale)}"; color: Theme.fg-muted; font-size: Theme.text-small; } }
                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                height: 30px;
                                border-radius: Theme.radius-md;
                                background: cnx.has-hover ? Theme.surface-3 : transparent;
                                HorizontalLayout {
                                    padding-left: 10px;
                                    padding-right: 12px;
                                    spacing: 5px;
                                    VerticalLayout { alignment: center; Icon { source: Icons.close; size: 13px; color: Theme.fg-muted; } }
                                    VerticalLayout { alignment: center; Text { text: @tr("Cancel"); color: Theme.fg; font-size: Theme.text-small; } }
                                }
                                cnx := Clickable { clicked => { root.tool = 0; } }
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                height: 30px;
                                border-radius: Theme.radius-md;
                                background: apx.has-hover ? Theme.accent-hover : Theme.accent;
                                HorizontalLayout {
                                    padding-left: 10px;
                                    padding-right: 12px;
                                    spacing: 5px;
                                    VerticalLayout { alignment: center; Icon { source: Icons.check; size: 13px; color: white; } }
                                    VerticalLayout { alignment: center; Text { text: @tr("Apply"); color: white; font-size: Theme.text-small; font-weight: 600; } }
                                }
                                apx := Clickable { clicked => { root.crop-apply(root.crop-l, root.crop-t, root.crop-r - root.crop-l, root.crop-b - root.crop-t, ta.width, ta.height, root.zoom); root.tool = 0; } }
                            }
                        }
                    }
                }
                // Zoom bar (bottom-right): −  ·  percent (click = fit)  ·  +
                // Hidden during crop — that mode has its own action bar.
                if root.tool != 8: Rectangle {
                    width: zb.preferred-width + 6px;
                    height: 32px;
                    x: stage.width - self.width - 12px;
                    y: stage.height - self.height - 12px;
                    background: Theme.surface-2;
                    border-width: 1px;
                    border-color: Theme.border-subtle;
                    border-radius: Theme.radius-md;
                    zb := HorizontalLayout {
                        padding: 3px;
                        spacing: 2px;
                        Rectangle {
                            width: 28px;
                            height: 26px;
                            border-radius: Theme.radius-sm;
                            background: zo.has-hover ? Theme.surface-3 : transparent;
                            Text { text: "−"; color: Theme.fg; font-size: Theme.text-heading; x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2; }
                            zo := TouchArea { mouse-cursor: pointer; clicked => { root.zoom = Math.max(root.zoom / 1.25, 0.25); } }
                        }
                        Rectangle {
                            width: 52px;
                            height: 26px;
                            border-radius: Theme.radius-sm;
                            background: zr.has-hover ? Theme.surface-3 : transparent;
                            Text { text: "\{Math.round(stage.fit * root.zoom * 100)}%"; color: Theme.fg; font-size: Theme.text-small; x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2; }
                            zr := TouchArea { mouse-cursor: pointer; clicked => { root.zoom = 1.0 / stage.fit; } }
                        }
                        Rectangle {
                            width: 28px;
                            height: 26px;
                            border-radius: Theme.radius-sm;
                            background: zi.has-hover ? Theme.surface-3 : transparent;
                            Text { text: "+"; color: Theme.fg; font-size: 15px; x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2; }
                            zi := TouchArea { mouse-cursor: pointer; clicked => { root.zoom = Math.min(root.zoom * 1.25, 4.0); } }
                        }
                    }
                }
                // Undo / redo — floating pill bottom-left, mirroring the zoom bar.
                // Hidden during crop to keep that mode focused.
                if root.tool != 8: Rectangle {
                    x: 12px;
                    y: stage.height - self.height - 12px;
                    width: ub.preferred-width + 6px;
                    height: 32px;
                    background: Theme.surface-2;
                    border-width: 1px;
                    border-color: Theme.border-subtle;
                    border-radius: Theme.radius-md;
                    ub := HorizontalLayout {
                        padding: 3px;
                        spacing: 2px;
                        Rectangle {
                            width: 30px;
                            height: 26px;
                            border-radius: Theme.radius-sm;
                            background: ud.has-hover ? Theme.surface-3 : transparent;
                            Icon { source: Icons.restart; size: 15px; color: Theme.fg-muted; }
                            ud := TouchArea { mouse-cursor: pointer; clicked => { root.undo(); } }
                        }
                        Rectangle {
                            width: 30px;
                            height: 26px;
                            border-radius: Theme.radius-sm;
                            background: rd.has-hover ? Theme.surface-3 : transparent;
                            Icon { source: Icons.redo; size: 15px; color: Theme.fg-muted; }
                            rd := TouchArea { mouse-cursor: pointer; clicked => { root.redo(); } }
                        }
                    }
                }
                // Text tool — inline editor placed at the click; Enter commits.
                // Always present (parked off-screen when idle) so it's realized
                // and can actually take focus; click focuses it via `ti.focus()`.
                ti := TextInput {
                    x: root.text-editing ? root.text-x : -3000px;
                    y: root.text-y;
                    width: 360px;
                    color: root.draw-color;
                    font-size: root.text-size * 1px;
                    font-family: root.text-font-name;
                    text <=> root.text-buffer;
                    single-line: true;
                    accepted => {
                        root.add-text(root.text-x, root.text-y, stage.width, stage.height, root.text-buffer, root.draw-color, root.text-size, root.text-font, root.zoom);
                        root.text-editing = false;
                        fs.focus();
                    }
                }
            }
        }
        // Background panel — an in-window overlay (not a PopupWindow) so it grows
        // and shrinks with its content without the popup fixed-size glitch.
        if root.bg-open: Rectangle {
            width: 100%;
            height: 100%;
            TouchArea { clicked => { root.bg-open = false; } }
            Rectangle {
                x: Math.clamp(bgtrig.absolute-position.x - 133px, 8px, root.width - 308px);
                y: bgtrig.absolute-position.y + 38px;
                width: 300px;
                height: bgpanel.preferred-height;
                background: Theme.surface-1;
                border-radius: Theme.radius-xl;
                border-width: 1px;
                border-color: Theme.border-subtle;
                drop-shadow-blur: 24px;
                drop-shadow-offset-y: 6px;
                drop-shadow-color: #00000055;
                TouchArea { }
                bgpanel := VerticalLayout {
                    padding: 14px;
                    spacing: 14px;
                    // ── Main panel: preset grid + (when on) controls ──
                    if !root.bg-cp-open: VerticalLayout {
                        spacing: 14px;
                        HorizontalLayout {
                            spacing: 8px;
                            BgChip { swatch: Theme.surface-2; has-glyph: true; glyph: Icons.close; selected: root.bg-preset == 0; clicked => { root.bg-off(); } }
                            BgChip { swatch: #0f172a; selected: root.bg-preset == 1; clicked => { root.pick-bg-preset(1); } }
                            BgChip { swatch: #f8fafc; selected: root.bg-preset == 2; clicked => { root.pick-bg-preset(2); } }
                            BgChip { swatch: @linear-gradient(135deg, #38bdf8 0%, #1d4ed8 100%); selected: root.bg-preset == 3; clicked => { root.pick-bg-preset(3); } }
                            BgChip { swatch: @linear-gradient(135deg, #34d399 0%, #06b6d4 100%); selected: root.bg-preset == 4; clicked => { root.pick-bg-preset(4); } }
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            BgChip { swatch: @linear-gradient(135deg, #fb923c 0%, #ec4899 100%); selected: root.bg-preset == 5; clicked => { root.pick-bg-preset(5); } }
                            BgChip { swatch: @linear-gradient(135deg, #a855f7 0%, #2563eb 100%); selected: root.bg-preset == 6; clicked => { root.pick-bg-preset(6); } }
                            BgChip { swatch: @linear-gradient(135deg, #f43f5e 0%, #7c2d12 100%); selected: root.bg-preset == 7; clicked => { root.pick-bg-preset(7); } }
                            BgChip { swatch: Theme.surface-2; has-glyph: true; glyph: Icons.eye-off; selected: root.bg-preset == 8; clicked => { root.pick-bg-preset(8); } }
                            // Custom colour — opens the HSV picker.
                            Rectangle {
                                horizontal-stretch: 1;
                                height: self.width;
                                border-radius: self.width * 0.26;
                                background: root.bg-color;
                                border-width: root.bg-preset == 9 ? 2.5px : 1px;
                                border-color: root.bg-preset == 9 ? Theme.accent : Theme.border-strong;
                                Text { text: "+"; color: white; font-size: 18px; font-weight: 600; x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2; }
                                Clickable { clicked => { root.bg-open-picker(); root.bg-cp-open = true; } }
                            }
                        }
                        // Controls — only meaningful when a backdrop is active.
                        if root.bg-on: VerticalLayout {
                            spacing: 12px;
                            Rectangle { height: 1px; background: Theme.border-subtle; }
                            VerticalLayout {
                                spacing: 6px;
                                Text { text: @tr("Aspect"); color: Theme.fg-muted; font-size: Theme.text-small; }
                                Segmented { fill: true; width: parent.width; options: [@tr("Free"), "1:1", "16:9", "9:16", "4:3"]; selected <=> root.bg-aspect; changed(i) => { root.set-bg-aspect(i); } }
                            }
                            VerticalLayout {
                                spacing: 6px;
                                Text { text: @tr("Padding"); color: Theme.fg-muted; font-size: Theme.text-small; }
                                Segmented { fill: true; width: parent.width; options: ["0", "16", "32", "64", "96"]; selected <=> root.bg-pad-idx; changed(i) => { root.set-bg-padding(i == 0 ? 0 : i == 1 ? 16 : i == 2 ? 32 : i == 3 ? 64 : 96); } }
                            }
                            VerticalLayout {
                                spacing: 6px;
                                Text { text: @tr("Radius"); color: Theme.fg-muted; font-size: Theme.text-small; }
                                Segmented { fill: true; width: parent.width; options: ["0", "8", "16", "24", "32"]; selected <=> root.bg-rad-idx; changed(i) => { root.set-bg-radius(i == 0 ? 0 : i == 1 ? 8 : i == 2 ? 16 : i == 3 ? 24 : 32); } }
                            }
                            Rectangle { height: 1px; background: Theme.border-subtle; }
                            HorizontalLayout {
                                spacing: 8px;
                                VerticalLayout { alignment: center; Text { text: @tr("Shadow"); color: Theme.fg; font-size: Theme.text-body; } }
                                Rectangle { }
                                VerticalLayout { alignment: center; Toggle { on <=> root.bg-shadow; toggled(v) => { root.set-bg-shadow(v); } } }
                            }
                            if root.bg-shadow: HorizontalLayout {
                                spacing: 10px;
                                VerticalLayout { alignment: center; Text { text: @tr("Strength"); color: Theme.fg-muted; font-size: Theme.text-body; } }
                                VerticalLayout { alignment: center; horizontal-stretch: 1; Slider { minimum: 0; maximum: 100; value <=> root.bg-shadow-strength; changed(v) => { root.set-bg-strength(v); } } }
                            }
                            Rectangle {
                                height: 32px;
                                border-radius: Theme.radius-md;
                                background: rst.has-hover ? Theme.surface-2 : transparent;
                                border-width: 1px;
                                border-color: Theme.border-subtle;
                                Text { text: @tr("Reset background"); color: Theme.fg-muted; font-size: Theme.text-small; x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2; }
                                rst := Clickable { clicked => { root.reset-bg(); } }
                            }
                        }
                    }
                    // ── Custom-colour picker (HSV square + hue bar + hex) ──
                    if root.bg-cp-open: VerticalLayout {
                        spacing: 12px;
                        HorizontalLayout {
                            spacing: 8px;
                            VerticalLayout { alignment: center; Rectangle { width: 28px; height: 28px; border-radius: Theme.radius-sm; background: bkt.has-hover ? Theme.surface-2 : transparent; Icon { source: Icons.chevron-left; size: 16px; color: Theme.fg-muted; } bkt := Clickable { clicked => { root.bg-cp-open = false; } } } }
                            VerticalLayout { horizontal-stretch: 1; alignment: center; Text { text: @tr("Custom colour"); color: Theme.fg; font-size: Theme.text-title; font-weight: 600; } }
                        }
                        Rectangle {
                            height: 132px;
                            border-radius: Theme.radius-md;
                            clip: true;
                            background: Colors.hsv(root.bg-hue * 360, 1, 1);
                            Rectangle { width: 100%; height: 100%; background: @linear-gradient(90deg, #ffffff 0%, #ffffff00 100%); }
                            Rectangle { width: 100%; height: 100%; background: @linear-gradient(0deg, #000000 0%, #00000000 100%); }
                            Rectangle { width: 14px; height: 14px; border-radius: Theme.radius-md; border-width: 2px; border-color: white; x: root.bg-sat * parent.width - self.width / 2; y: (1 - root.bg-val) * parent.height - self.height / 2; }
                            sva := TouchArea {
                                moved => { root.bg-sat = Math.clamp(self.mouse-x / self.width, 0, 1); root.bg-val = 1 - Math.clamp(self.mouse-y / self.height, 0, 1); root.bg-solid(Colors.hsv(root.bg-hue * 360, root.bg-sat, root.bg-val), false); }
                                clicked => { root.bg-sat = Math.clamp(self.mouse-x / self.width, 0, 1); root.bg-val = 1 - Math.clamp(self.mouse-y / self.height, 0, 1); root.bg-solid(Colors.hsv(root.bg-hue * 360, root.bg-sat, root.bg-val), false); }
                            }
                        }
                        Rectangle {
                            height: 16px;
                            border-radius: Theme.radius-md;
                            clip: true;
                            background: @linear-gradient(90deg, #ff0000 0%, #ffff00 16.6%, #00ff00 33.3%, #00ffff 50%, #0000ff 66.6%, #ff00ff 83.3%, #ff0000 100%);
                            Rectangle { width: 4px; height: 100%; border-radius: Theme.radius-xs; background: white; x: root.bg-hue * parent.width - self.width / 2; }
                            hua := TouchArea {
                                moved => { root.bg-hue = Math.clamp(self.mouse-x / self.width, 0, 1); root.bg-solid(Colors.hsv(root.bg-hue * 360, root.bg-sat, root.bg-val), false); }
                                clicked => { root.bg-hue = Math.clamp(self.mouse-x / self.width, 0, 1); root.bg-solid(Colors.hsv(root.bg-hue * 360, root.bg-sat, root.bg-val), false); }
                            }
                        }
                        Rectangle {
                            height: 32px;
                            border-radius: Theme.radius-md;
                            background: Theme.surface-input;
                            border-width: 1px;
                            border-color: hx.has-focus ? Theme.accent : Theme.border-strong;
                            clip: true;
                            if root.bg-hex == "": Text { x: 10px; y: (parent.height - self.height) / 2; text: @tr("#hex"); color: Theme.fg-subtle; font-size: Theme.text-body; }
                            hx := TextInput { x: 10px; width: parent.width - 20px; height: 100%; text <=> root.bg-hex; color: Theme.fg; font-size: Theme.text-body; single-line: true; vertical-alignment: center; accepted => { root.bg-hex-commit(root.bg-hex); } }
                        }
                    }
                }
            }
        }
    }
}
