                        mouse-cursor: MouseCursor.crosshair;
                        pointer-event(event) => {
                            if (event.kind == PointerEventKind.down) {
                                if (Math.abs(cta.pressed-x - root.crop-l) < 14px && Math.abs(cta.pressed-y - root.crop-t) < 14px) { root.crop-handle = 1; }
                                else if (Math.abs(cta.pressed-x - root.crop-r) < 14px && Math.abs(cta.pressed-y - root.crop-t) < 14px) { root.crop-handle = 3; }
                                else if (Math.abs(cta.pressed-x - root.crop-r) < 14px && Math.abs(cta.pressed-y - root.crop-b) < 14px) { root.crop-handle = 5; }
                                else if (Math.abs(cta.pressed-x - root.crop-l) < 14px && Math.abs(cta.pressed-y - root.crop-b) < 14px) { root.crop-handle = 7; }
                                else if (Math.abs(cta.pressed-x - (root.crop-l + root.crop-r) / 2) < 14px && Math.abs(cta.pressed-y - root.crop-t) < 14px) { root.crop-handle = 2; }
                                else if (Math.abs(cta.pressed-x - root.crop-r) < 14px && Math.abs(cta.pressed-y - (root.crop-t + root.crop-b) / 2) < 14px) { root.crop-handle = 4; }
                                else if (Math.abs(cta.pressed-x - (root.crop-l + root.crop-r) / 2) < 14px && Math.abs(cta.pressed-y - root.crop-b) < 14px) { root.crop-handle = 6; }
                                else if (Math.abs(cta.pressed-x - root.crop-l) < 14px && Math.abs(cta.pressed-y - (root.crop-t + root.crop-b) / 2) < 14px) { root.crop-handle = 8; }
                                else if (cta.pressed-x > root.crop-l && cta.pressed-x < root.crop-r && cta.pressed-y > root.crop-t && cta.pressed-y < root.crop-b) {
                                    root.crop-handle = 9;
                                    root.crop-l0 = root.crop-l;
                                    root.crop-t0 = root.crop-t;
                                    root.crop-w0 = root.crop-r - root.crop-l;
                                    root.crop-h0 = root.crop-b - root.crop-t;
