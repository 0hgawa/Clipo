                                root.crop-t = Math.clamp(root.crop-t0 + (cta.mouse-y - cta.pressed-y), root.crop-iy0, root.crop-iy1 - root.crop-h0);
                                root.crop-r = root.crop-l + root.crop-w0;
                                root.crop-b = root.crop-t + root.crop-h0;
                            }
                        }
                        Rectangle { x: 0; y: 0; width: parent.width; height: root.crop-t; background: #00000088; }
                        Rectangle { x: 0; y: root.crop-b; width: parent.width; height: parent.height - root.crop-b; background: #00000088; }
                        Rectangle { x: 0; y: root.crop-t; width: root.crop-l; height: root.crop-b - root.crop-t; background: #00000088; }
                        Rectangle { x: root.crop-r; y: root.crop-t; width: parent.width - root.crop-r; height: root.crop-b - root.crop-t; background: #00000088; }
                        Rectangle { x: root.crop-l; y: root.crop-t; width: root.crop-r - root.crop-l; height: root.crop-b - root.crop-t; background: transparent; border-width: 1.5px; border-color: #fffffff2; }
                        CropHandle { cx: root.crop-l; cy: root.crop-t; }
                        CropHandle { cx: root.crop-r; cy: root.crop-t; }
                        CropHandle { cx: root.crop-r; cy: root.crop-b; }
                        CropHandle { cx: root.crop-l; cy: root.crop-b; }
                        CropHandle { pill-h: true; cx: (root.crop-l + root.crop-r) / 2; cy: root.crop-t; }
                        CropHandle { pill-h: true; cx: (root.crop-l + root.crop-r) / 2; cy: root.crop-b; }
                        CropHandle { pill-v: true; cx: root.crop-r; cy: (root.crop-t + root.crop-b) / 2; }
                        CropHandle { pill-v: true; cx: root.crop-l; cy: (root.crop-t + root.crop-b) / 2; }
                    }
