msgid "Interface language. Affects every Clipo window. Takes effect immediately."
msgstr "Язык интерфейса. Влияет на все окна Clipo. Применяется сразу."

msgid "Launch Clipo at system startup"
msgstr "Запускать Clipo при старте системы"

msgid "Clipo lives in the system tray. With this on, it starts automatically at login."
msgstr "Clipo находится в области уведомлений. Если включено, запускается автоматически при входе в систему."

msgid "Open images with Clipo"
msgstr "Открывать изображения в Clipo"

msgid "Tray icon left-click"
msgstr "Левый клик по значку"

msgid "What a left-click on the tray icon does. Right-click always opens the menu."
msgstr "Что делает левый клик по значку в трее. Правый клик всегда открывает меню."

